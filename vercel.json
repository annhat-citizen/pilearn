{
  "buildCommand": "npm install && vite build",
  "outputDirectory": "dist",
  "framework": null,
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/tutor", "destination": "/api/tutor" },
    { "source": "/api/analyze-code", "destination": "/api/analyze-code" },
    { "source": "/api/grade", "destination": "/api/grade" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
